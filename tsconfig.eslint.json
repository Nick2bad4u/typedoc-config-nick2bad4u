{
    "$schema": "https://www.schemastore.org/tsconfig.json",
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "declaration": false,
        "declarationMap": false,
        "isolatedDeclarations": false,
        "noEmit": true
    },
    "exclude": [
        ".cache/**",
        "coverage/**",
        "dist/**",
        "node_modules/**"
    ],
    "extends": "./tsconfig.json",
    "include": [
        "*.cjs",
        "*.mjs",
        "*.ts",
        ".github/**/*.yml",
        ".github/**/*.yaml",
        "scripts/**/*.mjs",
        "src/**/*.ts",
        "test/**/*.ts",
        "typedoc-plugins/**/*.d.mts",
        "typedoc-plugins/**/*.mjs",
        "vite.config.ts"
    ]
}
