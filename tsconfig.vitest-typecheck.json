{
    "$schema": "https://www.schemastore.org/tsconfig.json",
    "compilerOptions": {
        "noEmit": true,
        "types": [
            "node",
            "vitest/globals"
        ]
    },
    "exclude": [
        ".cache/**",
        "coverage/**",
        "dist/**",
        "node_modules/**"
    ],
    "extends": "./tsconfig.json",
    "include": [
        "src/**/*.ts",
        "test/**/*.ts"
    ]
}
